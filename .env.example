# Client flag: set to "true" to show the AI chat widget in the browser bundle.
# Safe to expose — this is a non-secret feature toggle, not a credential.
VITE_GEMINI_ENABLED=false

# Server-only Google Gemini API key — read by the Express proxy (server/geminiProxy.ts).
# Get one at https://aistudio.google.com/app/apikey
# DO NOT prefix this with VITE_. Vite inlines every VITE_* variable into the public
# client bundle; the key must stay server-side and reach Gemini only via the proxy.
GEMINI_API_KEY=

# Optional (server-only). Comma-separated CORS allowlist for the chat proxy. When set,
# it replaces the built-in defaults (production origin + localhost dev ports). Configure
# this in production instead of editing the code when the hostname or custom domain changes.
# Example: ALLOWED_CHAT_ORIGINS=https://kyle-semple.example.com,https://www.kyle-semple.example.com
ALLOWED_CHAT_ORIGINS=

# Optional (server-only). Per-IP daily request cap for the chat proxy (default 25).
DIGITAL_TWIN_MAX_DAILY_REQUESTS=
