{
  "name": "kyle-semple-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.json && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest",
    "serve": "tsx server/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run serve\"",
    "generate:crawler-html": "node scripts/generate-crawler-html.mjs",
    "validate:crawler": "node scripts/validate-crawler.mjs",
    "build:crawler": "npm run build && npm run generate:crawler-html",
    "generate:resume-pdf": "npm run build && node scripts/generate-resume-pdf.mjs",
    "validate:phase": "node scripts/validate-phase.mjs",
    "fix:format": "npm run format && npm run format:check",
    "sync:architect": "repomix --config repomix.architect.config.json",
    "defense:codex": "node scripts/run-appellate-defense.mjs",
    "review:jules": "node scripts/run-jules-review.mjs",
    "docs:generate": "node scripts/run-documentation.mjs",
    "resolve:coach": "node scripts/run-resolution.mjs",
    "capture:media": "tsx scripts/capture-media.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "dompurify": "^3.4.9",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.6",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.3",
    "repomix": "^1.14.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "proseWrap": "preserve"
  }
}
